{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "node",
    "allowJs": true,
    "jsx": "react-jsx",
        "baseUrl": ".",

    "paths": {
      "@/*": [
        "./*"
      ],
      "model/*": ["./model/*"],
      "utils/*": ["./utils/*"],


    },
    "noEmit": true
  }
}
